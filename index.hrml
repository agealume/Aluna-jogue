<!DOCTYPE html>
<html lang="pt-ao">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aluna Platform</title>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        // ─── CONSTANTES ───────────────────────────────────────────────────────────────
        const PROVINCES = ["Luanda","Benguela","Huambo","Huíla","Cabinda","Malanje","Uíge","Lunda Norte","Lunda Sul","Moxico","Cuando Cubango","Cunene","Namibe","Bié","Kwanza Norte","Kwanza Sul","Zaire","Bengo","Kuando","Icolo e Bengo"];
        const EDUCATION_LEVELS = ["Ensino Primário","7ª Classe","8ª Classe","9ª Classe","10ª Classe","11ª Classe","12ª Classe","Bacharel","Licenciatura","Mestrado","Doutoramento"];
        const BET_AMOUNTS_IA   = [100,200,300,500,1000,1500,2000,3000,5000];
        const BET_AMOUNTS_REAL = [150,250,500,1000,1500,2000,5000];
        const QUESTIONS = [
            {q:"Qual é a capital de Angola?", opts:["Luanda","Benguela","Huambo","Malanje"], a:0},
            {q:"Em que ano Angola se tornou independente?", opts:["1972","1975","1980","1968"], a:1},
            {q:"Qual é a moeda oficial de Angola?", opts:["Real","Kwanza","Escudo","Franco"], a:1},
            {q:"Qual é o rio mais longo de Angola?", opts:["Kwanza","Congo","Cunene","Kubango"], a:0},
            {q:"Qual é o maior país de língua portuguesa?", opts:["Portugal","Angola","Brasil","Moçambique"], a:2},
            {q:"Em que oceano está Angola?", opts:["Índico","Pacífico","Atlântico","Ártico"], a:2},
            {q:"Qual é o animal símbolo de Angola?", opts:["Leão","Palanca Negra","Elefante","Zebra"], a:1},
            {q:"Quem foi o primeiro presidente de Angola?", opts:["José Eduardo dos Santos","Agostinho Neto","João Lourenço","Holden Roberto"], a:1},
            {q:"Qual é a língua oficial de Angola?", opts:["Kimbundu","Kikongo","Português","Umbundu"], a:2},
            {q:"Quantas províncias tem Angola?", opts:["14","16","18","20"], a:2},
        ];
        const WIN_MSG  = ["🏆 Você é um génio absoluto!","🔥 Impressionante! Angola te saúda!","⭐ Mente brilhante em ação!","💎 Conhecimento é poder!","🚀 Imparável! Continue assim!"];
        const LOSE_MSG = ["📚 Estude mais e volte mais forte!","💪 Os campeões não desistem!","🌱 Cada erro é uma lição valiosa!","🔄 Tente novamente — você consegue!","🎯 O conhecimento te espera!"];
        
        const css = `
        @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700;800&display=swap');
        *{margin:0;padding:0;box-sizing:border-box;}
        :root{
          --red:#CC1A1A;--gold:#F0A500;--yellow:#FFD700;--black:#0A0A0A;
          --surface:#111;--surface2:#1A1A1A;--surface3:#242424;
          --green:#00C97F;--white:#F5F5F0;--muted:#888;--border:#2A2A2A;
        }
        body{font-family:'Outfit',sans-serif;background:var(--black);color:var(--white);overflow-x:hidden;}
        .app{max-width:480px;margin:0 auto;min-height:100vh;background:var(--black);display:flex;flex-direction:column;}
        .header{background:linear-gradient(135deg,#0d0000,#1a0505,var(--black));border-bottom:2px solid var(--gold);padding:16px 20px;display:flex;align-items:center;justify-content:space-between;}
        .logo{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:3px;background:linear-gradient(135deg,var(--yellow),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
        .card{background:var(--surface2);border:1px solid var(--border);border-radius:16px;padding:20px;margin:20px;}
        .btn{padding:14px 24px;border-radius:12px;font-weight:700;cursor:pointer;border:none;width:100%;}
        .btn-gold{background:linear-gradient(135deg,var(--yellow),var(--gold));color:var(--black);}
        .input{width:100%;background:var(--surface3);border:1px solid var(--border);border-radius:10px;padding:13px 16px;color:var(--white);margin-top:8px;}
        `;

        // ─── COMPONENTES ─────────────────────────────────────────────────────────────
        function App() {
            const [user, setUser] = useState(null);
            const [loading, setLoading] = useState(true);

            useEffect(() => {
                setTimeout(() => setLoading(false), 2000);
            }, []);

            if (loading) {
                return (
                    <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",minHeight:"100vh",background:"var(--black)"}}>
                        <style>{css}</style>
                        <div style={{fontFamily:"'Bebas Neue',sans-serif",fontSize:60,color:"var(--gold)"}}>Aluna</div>
                        <p style={{color:"#888"}}>Carregando...</p>
                    </div>
                );
            }

            return (
                <div className="app">
                    <style>{css}</style>
                    <div className="header">
                        <div className="logo">Aluna</div>
                        {user && <div style={{color:"var(--gold)"}}>{user.balance} Kz</div>}
                    </div>
                    
                    {!user ? (
                        <div className="card">
                            <h2 style={{fontFamily:"'Bebas Neue'", fontSize:32, color:"var(--gold)"}}>Entrar</h2>
                            <input className="input" type="email" placeholder="E-mail" />
                            <input className="input" type="password" placeholder="Senha" />
                            <button className="btn btn-gold" style={{marginTop:20}} onClick={() => setUser({balance: 1500})}>
                                Entrar na Aluna
                            </button>
                        </div>
                    ) : (
                        <div className="card">
                            <p>Bem-vindo de volta!</p>
                            <button className="btn btn-gold" style={{marginTop:20}} onClick={() => setUser(null)}>Sair</button>
                        </div>
                    )}
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
